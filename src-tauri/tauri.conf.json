{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Platypus",
  "version": "0.1.0",
  "identifier": "com.platypus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Platypus",
        "width": 480,
        "height": 680,
        "resizable": false,
        "center": true,
        "decorations": true
      },
      {
        "label": "companion",
        "title": "",
        "url": "index.html#companion",
        "width": 260,
        "height": 260,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
