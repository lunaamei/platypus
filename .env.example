# Local dev: call GitHub Models directly with your own PAT.
VITE_GITHUB_MODELS_KEY=github_pat_...

# Production/public build: point at your deployed Cloudflare Worker proxy
# instead (see cloudflare-worker/) so the real key never ships in the bundle.
# VITE_API_PROXY_URL=https://platypus-ai-proxy.your-subdomain.workers.dev
